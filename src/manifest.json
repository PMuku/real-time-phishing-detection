{
    "name": "My Anti-Phishing Extension",
    "version": "1.0",
    "manifest_version": 3,
    "description": "A real-time anti-phishing browser extension.",
    "permissions": ["activeTab", "scripting", "storage", "offscreen"],
    "host_permissions": ["<all_urls>"],
    "background": {
        "service_worker": "serviceWorker.bundle.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.bundle.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["ml/lexical_model.json"],
            "matches": ["<all_urls>"]
        }
    ]
    
}